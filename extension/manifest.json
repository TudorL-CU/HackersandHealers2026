{
  "manifest_version": 3,
  "name": "Continuity Copilot",
  "description": "Longitudinal patient intelligence for primary care clinicians",
  "version": "0.2.0",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open Continuity Copilot"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
